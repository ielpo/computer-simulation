    <slider x="1185" step="1" y="110" max="100" width="250" display="headcount-variance" height="50" min="0" direction="Horizontal" default="10.0" variable="headcount-variance" units="%"></slider>
    <slider x="1185" step="100" y="170" max="10000" width="250" display="hiring-threshold-mean" height="50" min="0" direction="Horizontal" default="1700.0" variable="hiring-threshold-mean"></slider>
    <slider x="1185" step="50" y="230" max="500" width="250" display="hiring-threshold-variance" height="50" min="0" direction="Horizontal" default="300.0" variable="hiring-threshold-variance"></slider>
    <slider x="1450" step="10" y="50" max="500" width="250" display="strategy-review-interval" height="50" min="10" direction="Horizontal" default="50.0" variable="strategy-review-interval" units="ticks"></slider>
    <switch x="1450" y="120" height="40" on="true" variable="dynamic-hiring-strategy" width="250" display="dynamic-hiring-strategy"></switch>
