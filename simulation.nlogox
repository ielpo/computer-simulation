<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[extensions [ profiler rnd ]

turtles-own [
  age                       ;; age in years
  skill-level               ;; skill level of agent
  propensity-to-leave      ;; probability to leave company at each tick
  last-coaching             ;; tick count at last coaching
]

patches-own [
  headcount                 ;; target number of employees
  total-skill               ;; sum of skill-level of company
  hiring-threshold          ;; minimum skill required to hire an agent
  coaching-rate             ;; amount of time spent coaching instead of working
  effective-coaching-rate   ;; coaching-rate adjusted for vacancy pressure
  activity                  ;; activity chosen for current tick
  revenue                   ;; revenue of company for current tick
  cumulative-revenue        ;; revenue for strategy evaluation
  last-review               ;; tick count at last strategy review
  developer-history         ;; history of developers leaving company
  developers-leaving        ;; number of developers leaving company in this tick
]

globals [
  ticks-per-year
  turnovers-this-tick
  coaching-rate-options
  developer-history-count
  market-mean-skill         ;; average skill across all employed developers
  market-mean-revenue       ;; average revenue across all companies
]


;; ---------------------------------------
;; setup
;; ---------------------------------------
to setup
  clear-all

  set ticks-per-year 100
  set developer-history-count 100
   
  set coaching-rate-options n-values max-coaching-rate [i -> i] ;; yields [0, 1, ..., max-coaching-rate - 1]; max value excluded

  setup-patches
  setup-turtles
  
  update-market-stats
  color-patches

  reset-ticks
end


to setup-patches ;; observer procedure
  ;; initialize the companies
  ask patches with [self != patch 0 0] [
    set headcount round (random-normal headcount-mean (headcount-variance * headcount-mean / 100))
    set hiring-threshold round (random-normal hiring-threshold-mean hiring-threshold-variance)
    set coaching-rate one-of coaching-rate-options
    set effective-coaching-rate coaching-rate
    set developer-history []

    sprout headcount
  ]
  ;; unemployed pool (patch 0 0) is initialized by default with 0 for everything 
end


to-report initial-skill [ for-age ]
  ;; ranges from ~1000 (age 20) to ~7200 (age 65)
  report round (1000 + ((for-age - 20) / 45) * 6000 + (random-float 200))
end

to-report age-probability [ for-age ]
  ;; probability of age: linear increase until age 30 then uniform
  ;; this reflects the probability of ages when new agents spawn after a retirement
  ifelse (for-age < 30)
  [ report ((for-age - 20) / 10) ]
  [ report 1 ]
end

;; initialize the developers
to setup-turtles
  let possible-ages n-values 45 [ i -> i + 20 ]
  ask turtles [
    set age (rnd:weighted-one-of-list possible-ages age-probability) + random-float 1
    set skill-level initial-skill age
    hide-turtle
  ]
  ;; update the patches
  ask patches [ set total-skill sum [skill-level] of turtles-here ]
end


;; ---------------------------------------
;; go - run one simulation timestep
;; ---------------------------------------
to go
  set turnovers-this-tick 0
  ask patches [set developers-leaving 0]
  
  turnover
  increase-age
  update-market-stats

  ask patches with [self != patch 0 0] [
    set revenue 0
    
    ;; limit length of developer history
    if length developer-history > developer-history-count [
      set developer-history sublist developer-history 0 (developer-history-count - 1)
    ]
    
    fill-vacancies
    
    choose-activity
    execute-activity
    
    set total-skill sum [skill-level] of turtles-here
    if (activity = "work") [ set revenue total-skill ]
    set cumulative-revenue (cumulative-revenue + revenue)

    if (dynamic-hiring-strategy and ticks - last-review > strategy-review-interval) [
      update-strategy
      set last-review ticks
    ]
  ]

  color-patches
  tick
end

;; ---------------------------------------
;; Procedures for simulation
;; ---------------------------------------
to turnover ;; observer procedure
  ask turtles with [patch-here != patch 0 0] [
    if (propensity-to-leave > leaving-threshold) [
      let departure-record (list skill-level ticks)
      ask patch-here [
        set developer-history lput departure-record developer-history
        set developers-leaving (developers-leaving + 1)
      ]
      
      ;; if there is a fitting company switch, else unemployment
      let eligible-companies patches with [
        headcount > count turtles-here and hiring-threshold < [skill-level] of myself
      ]
      
      ifelse (any? eligible-companies)
      [
        let selected-company max-one-of eligible-companies [company-appeal [skill-level] of myself developer-history]
        move-to selected-company
      ]
      [ move-to patch 0 0 ]
      set propensity-to-leave 0
      set turnovers-this-tick (turnovers-this-tick + 1) 
    ]
  ]
end

to increase-age ;; observer procedure
  ask turtles [
    set age (age + (1 / ticks-per-year))
    if (age >= 65.0) [ ;; retiree is replaced immediately by a new (young) labor market entrant
      hatch 1 [
        setxy 0 0
        set age 20 + random 10
        set skill-level initial-skill age
        set last-coaching ticks
        hide-turtle
      ]
      die
    ]
  ]
end

to-report company-appeal [given-skill-level given-developer-history]
  let appeal 0  ;; Initialize appeal value
  foreach given-developer-history [ record -> 
    let departure-skill-level item 0 record
    let departure-tick item 1 record
    let ratio (ln (given-skill-level / departure-skill-level)) ^ 2  ;; Calculate squared-log ratio, highest appeal when no similar developers left lately
    let weight 1 / (ticks - departure-tick + 1)  ;; Weight by ticks
    set appeal appeal + (ratio * weight)  ;; Add weighted ratio to appeal
  ]
  report appeal
end

to fill-vacancies ;; patch procedure
  let vacancies (headcount - (count turtles-here))
  if (vacancies > 0) [
    ;; Identify all qualified candidates and pick one randomly
    let candidates (turtles-on patch 0 0) with [skill-level > [hiring-threshold] of myself]
    if any? candidates [
      ;; get up to vacancies candidates from the pool
      ask n-of (min (list vacancies (count candidates))) candidates [
        move-to myself
      ]
    ]
  ]
end

to choose-activity ;; patch procedure
  if not any? turtles-here [ stop ]
  set effective-coaching-rate coaching-rate
  if vacancy-rate-pressure [
    ;; understaffed companies are forced to reduce coaching to keep up with demand
    let vacancy-rate 1 - ((count turtles-here) / headcount)
    set effective-coaching-rate coaching-rate * (1 - vacancy-rate)
  ]
  ifelse (random-float 100 < effective-coaching-rate)
    [ set activity "coach" ]
    [ set activity "work" ]
end

to execute-activity ;; patch procedure
  if not any? turtles-here [ stop ]
  if activity = "coach" [
    ask turtles-here [ do-coaching ]
  ]
  if activity = "work" [
    ask turtles-here [ do-work ]
  ]
end

to do-coaching  ;; turtle procedure
  ifelse (diminishing-returns-coaching)
  ;; exponential decay towards coaching-skill-ceiling
    [ set skill-level round (skill-level + coaching-skill-increase * (1 - (skill-level / coaching-skill-ceiling))) ]
    [ set skill-level round (skill-level + coaching-skill-increase) ]
  
  set propensity-to-leave max (list 0 (propensity-to-leave - coaching-turnover-decrease))
  set last-coaching ticks
end

to do-work  ;; turtle procedure
  set skill-level round (min (list (skill-level + working-skill-increase) coaching-skill-ceiling))
  
  let appeal company-appeal skill-level ([developer-history] of patch-here)
  set propensity-to-leave (propensity-to-leave - appeal * 0.1)
  set propensity-to-leave (propensity-to-leave + working-turnover-increase)
  ;; clamp to 0
  set propensity-to-leave max (list 0 propensity-to-leave)
  
  if (skill-decay and ((ticks - last-coaching) > skill-decay-threshold)) [
     ;; annual decay rate converted to per-tick
    set skill-level round (skill-level * (1 - skill-decay-rate / ticks-per-year)) 
  ]
end

to update-market-stats ;; observer procedure
  let employed turtles with [patch-here != patch 0 0]
  ifelse any? employed
    [ set market-mean-skill mean [skill-level] of employed ]
    [ set market-mean-skill 0 ]

  let companies patches with [self != patch 0 0]
  ifelse any? companies
    [ set market-mean-revenue mean [cumulative-revenue] of companies ]
    [ set market-mean-revenue 0 ]
end

;; ---------------------------------------
;; Strategy logic
;; ---------------------------------------
to update-strategy ;; patch procedure
  ;; rate of vacancies in one patch, between 0 (no vacancies) and 1 (no employees)
  let vacancy-rate 1 - ((count turtles-here) / headcount)
  
  ifelse (vacancy-rate > vacancy-rate-cutoff)
    [ set hiring-threshold (round (hiring-threshold * 0.7)) ]
    [ set hiring-threshold (round (hiring-threshold * 1.1)) ]
  ;; clamp value
  set hiring-threshold max (list 100 hiring-threshold)
  set hiring-threshold min (list hiring-threshold hiring-threshold-ceiling)
end

to color-patches ;; patch procedure
  ask patches with [self != patch 0 0] [
    let vacancy-rate 1 - ((count turtles-here) / headcount)
    set pcolor scale-color grey vacancy-rate 1 0
  ]
end

;; ---------------------------------------
;; Reporters for BehaviorSpace
;; ---------------------------------------

to-report revenue-distribution
  let companies patches with [self != patch 0 0]
  report ( list
    mean [revenue] of companies
    standard-deviation [revenue] of companies
    median [revenue] of companies
  )
end

to-report skill-distribution
  let developers turtles with [patch-here != patch 0 0]
  report (list 
    mean [skill-level] of developers
    standard-deviation [skill-level] of developers
    median [skill-level] of developers
  )
end

to-report turnover-rate
  report turnovers-this-tick
end

to-report unemployment-rate
  let unemployed-count count turtles-on patch 0 0
  report unemployed-count / (count turtles)
end

to-report headcount-of-companies
  let sorted-patches sort patches with [self != patch 0 0]
  report map [ p -> [headcount] of p ] sorted-patches
end

to-report dependent-variables
  let sorted-patches sort patches with [self != patch 0 0]
  report (list
    map [ p -> [cumulative-revenue] of p ] sorted-patches
    map [ p -> [coaching-rate] of p ] sorted-patches
    map [ p -> ([headcount] of p - count turtles-on p)] sorted-patches
    map [ p -> ifelse-value (any? turtles-on p) [mean [propensity-to-leave] of turtles-on p] [0] ] sorted-patches
  )
end


;; ---------------------------------------
;; Profiling
;; ---------------------------------------

to profile
  setup
  profiler:start         ;; start profiling
  repeat 100 [ go ]       ;; run something you want to measure
  profiler:stop          ;; stop profiling
  print profiler:report  ;; view the results
  profiler:reset         ;; clear the data
end
]]></code>
  <widgets>
    <view x="170" wrappingAllowedX="false" y="10" frameRate="30.0" minPycor="0" height="504" showTickCounter="true" patchSize="50.0" fontSize="10" wrappingAllowedY="false" width="504" tickCounterLabel="ticks" maxPycor="9" updateMode="1" maxPxcor="9" minPxcor="0"></view>
    <monitor x="1030" precision="1" y="10" height="60" fontSize="11" width="120" display="Mean Skill Level">mean [skill-level] of turtles</monitor>
    <monitor x="910" precision="1" y="10" height="60" fontSize="11" width="110" display="Mean Age">mean
      [age] of turtles</monitor>
    <monitor x="800" precision="17" y="10" height="60" fontSize="11" width="100" display="Unemployed">count turtles with [xcor = 0 and ycor = 0]</monitor>
    <monitor x="685" precision="17" y="10" height="60" fontSize="11" width="105" display="Worker Count">count turtles</monitor>
    <button x="20" y="240" height="40" disableUntilTicks="false" forever="true" kind="Observer" width="125" display="Run Simulation">go</button>
    <button x="20" y="295" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="125" display="Step Simulation">go</button>
    <plot x="685" autoPlotX="false" yMax="1.0" autoPlotY="true" yAxis="Companies" y="80" xMin="0.0" height="185" legend="false" xMax="1.0" yMin="0.0" width="465" xAxis="Total Skill (Revenue)" display="Skill Distribution Companies">
