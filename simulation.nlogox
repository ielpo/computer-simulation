    <note x="1450" y="480" backgroundDark="0" fontSize="12" width="250" markdown="false" height="35" textColorDark="-1" textColorLight="-16777216" backgroundLight="0">Developer Behavior</note>
    <slider x="1450" step="1" y="525" max="100" width="250" display="leaving-threshold" height="50" min="0" direction="Horizontal" default="25.0" variable="leaving-threshold"></slider>
    <slider x="1450" step="0.05" y="645" max="5" width="250" display="coaching-turnover-decrease" height="50" min="0" direction="Horizontal" default="1.0" variable="coaching-turnover-decrease"></slider>
    <slider x="1450" step="0.05" y="585" max="0.5" width="250" display="working-turnover-increase" height="50" min="0" direction="Horizontal" default="0.15" variable="working-turnover-increase"></slider>
    <switch x="1450" y="300" height="40" on="false" variable="vacancy-rate-pressure" width="250" display="vacancy-rate-pressure"></switch>
    <note x="1185" y="370" backgroundDark="0" fontSize="12" width="250" markdown="false" height="35" textColorDark="-1" textColorLight="-16777216" backgroundLight="0">Coaching and Skill</note>
    <switch x="1185" y="405" height="40" on="true" variable="diminishing-returns-coaching" width="250" display="diminishing-returns-coaching"></switch>
    <slider x="1185" step="100" y="455" max="20000" width="250" display="coaching-skill-ceiling" height="50" min="2000" direction="Horizontal" default="10000.0" variable="coaching-skill-ceiling" units="sp"></slider>
    <slider x="1185" step="1" y="515" max="100" width="250" display="coaching-skill-increase" height="50" min="0" direction="Horizontal" default="20.0" variable="coaching-skill-increase" units="sp"></slider>
    <slider x="1185" step="1" y="575" max="10" width="250" display="working-skill-increase" height="50" min="0" direction="Horizontal" default="1.0" variable="working-skill-increase" units="sp"></slider>
    <switch x="1185" y="645" height="40" on="true" variable="skill-decay" width="250" display="skill-decay"></switch>
    <slider x="1185" step="0.005" y="755" max="0.2" width="250" display="skill-decay-rate" height="50" min="0" direction="Horizontal" default="0.1" variable="skill-decay-rate"></slider>
    <slider x="1185" step="10" y="695" max="800" width="250" display="skill-decay-threshold" height="50" min="100" direction="Horizontal" default="300.0" variable="skill-decay-threshold" units="ticks"></slider>
