      <update>clear-plot
let target-patches patches with [self != patch 0 0]
set-plot-x-range min [total-skill] of target-patches (max [total-skill] of target-patches + 1)
set-histogram-num-bars 20</update>
      <pen interval="1.0" mode="1" display="default" color="-16777216" legend="true">
        <setup></setup>
        <update>histogram [total-skill] of patches with [self != patch 0 0]</update>
      </pen>
    </plot>
    <plot x="685" autoPlotX="true" yMax="1.0" autoPlotY="true" yAxis="Companies" y="685" xMin="0.0" height="200" legend="false" xMax="10.1" yMin="0.0" width="465" xAxis="Coaching Rate" display="Coaching Rate Distribution">
      <setup></setup>
      <update>clear-plot
set-histogram-num-bars 11</update>
      <pen interval="1.0" mode="1" display="default" color="-16777216" legend="true">
        <setup></setup>
        <update>histogram [round effective-coaching-rate] of patches with [self != patch 0 0]</update>
      </pen>
    </plot>
    <plot x="685" autoPlotX="false" yMax="50.0" autoPlotY="true" yAxis="Workers" y="475" xMin="20.0" height="200" legend="false" xMax="66.0" yMin="0.0" width="465" xAxis="Age" display="Age Distribution">
      <setup></setup>
      <update>clear-plot
        set-histogram-num-bars 46
</update>
