  <linkShapes>
    <shape name="default" curviness="0.0">
      <lines>
        <line x="-0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
        <line x="0.0" visible="true">
          <dash value="1.0"></dash>
          <dash value="0.0"></dash>
        </line>
        <line x="0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
      </lines>
      <indicator>
        <shape name="link direction" rotatable="true" editableColorIndex="0">
          <line endX="90" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
          <line endX="210" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
        </shape>
      </indicator>
    </shape>
  </linkShapes>
  <previewCommands>setup repeat 75 [ go ]</previewCommands>
  <experiments>
    <experiment name="experiment" repetitions="20" sequentialRunOrder="true" runMetricsEveryStep="false">
      <setup>setup</setup>
      <go>go</go>
      <exitCondition><![CDATA[ticks >= 20000]]></exitCondition>
      <metrics>
        <metric>ifelse-value any? patches with [strategy = "talent-factory"] [ mean [cumulative-revenue] of patches with [strategy = "talent-factory"] ] [ 0 ]</metric>
        <metric>ifelse-value any? patches with [strategy = "cherry-picker"] [ mean [cumulative-revenue] of patches with [strategy = "cherry-picker"] ] [ 0 ]</metric>
        <metric>ifelse-value any? patches with [strategy = "goldilocks"] [ mean [cumulative-revenue] of patches with [strategy = "goldilocks"] ] [ 0 ]</metric>
        <metric>ifelse-value any? turtles with [patch-here != patch 0 0] [ mean [skill-level] of turtles with [patch-here != patch 0 0] ] [ 0 ]</metric>
        <metric>count turtles with [patch-here = patch 0 0]</metric>
      </metrics>
      <constants>
        <steppedValueSet variable="coaching-skill-increase" first="1" step="2" last="30"></steppedValueSet>
      </constants>
    </experiment>
    <experiment name="strategy-comparision" repetitions="20" sequentialRunOrder="true" runMetricsEveryStep="true">
      <setup>setup</setup>
      <go>go</go>
      <exitCondition><![CDATA[ticks >= 20000]]></exitCondition>
      <metrics>
        <metric>ifelse-value any? patches with [strategy = "talent-factory"] [ mean [total-skill] of patches with [strategy = "talent-factory"] ] [ 0 ]</metric>
        <metric>ifelse-value any? patches with [strategy = "cherry-picker"] [ mean [total-skill] of patches with [strategy = "cherry-picker"] ] [ 0 ]</metric>
        <metric>ifelse-value any? patches with [strategy = "goldilocks"] [ mean [total-skill] of patches with [strategy = "goldilocks"] ] [ 0 ]</metric>
        <metric>ifelse-value any? turtles with [patch-here != patch 0 0] [ mean [skill-level] of turtles with [patch-here != patch 0 0] ] [ 0 ]</metric>
        <metric>count turtles with [patch-here = patch 0 0]</metric>
      </metrics>
      <constants>
        <steppedValueSet variable="coaching-skill-increase" first="1" step="2" last="30"></steppedValueSet>
      </constants>
    </experiment>
  </experiments>
</model>
