    <!-- ═══════════════════════════════════════════════════════════════════
         Section 1: Basic analysis on coaching rate and output
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- Exp 1-1: How skill gains from coaching vs working affect output
         Sweeps: coaching-skill-increase (0→100 step 10),
                 working-skill-increase (0→10 step 1),
                 max-coaching-rate (0→20 step 5)
         Run count: 11 × 11 × 5 × 3 reps = 1,815 runs -->
    <experiment name="coaching-output-exp1" repetitions="3" sequentialRunOrder="false" runMetricsEveryStep="true" timeLimit="8000">
      <setup>setup</setup>
      <go>go</go>
      <runMetricsCondition>(ticks mod 10) = 0</runMetricsCondition>
      <metrics>
        <metric>dependent-variables</metric>
        <metric>revenue-distribution</metric>
        <metric>skill-distribution</metric>
        <metric>unemployment-rate</metric>
      </metrics>
      <constants>
        <steppedValueSet variable="coaching-skill-increase" first="0" step="10" last="100"></steppedValueSet>
        <steppedValueSet variable="working-skill-increase" first="0" step="2" last="10"></steppedValueSet>
        <steppedValueSet variable="max-coaching-rate" first="0" step="5" last="20"></steppedValueSet>
        <enumeratedValueSet variable="skill-decay">
          <value value="true"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="skill-decay-rate">
          <value value="0.1"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="skill-decay-threshold">
          <value value="300"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="vacancy-rate-cutoff">
          <value value="0.05"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="leaving-threshold">
          <value value="25"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="coaching-skill-ceiling">
          <value value="10000"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="hiring-threshold-mean">
          <value value="1700"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="hiring-threshold-variance">
          <value value="300"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="hiring-threshold-ceiling">
          <value value="13000"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="vacancy-rate-pressure">
          <value value="true"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="headcount-mean">
          <value value="30"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="headcount-variance">
          <value value="0"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="dynamic-hiring-strategy">
          <value value="true"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="diminishing-returns-coaching">
