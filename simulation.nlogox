<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[turtles-own [
  age                       ;; age in years
  skill-level               ;; skill level of agent
  turnover-probability      ;; probability ot leave comopany
]

patches-own [
  headcount                 ;; target number of employees
  total-skill               ;; sum of skill-level of company
  hiring-threshold          ;; minimum skill required to hire an agent
  coaching-rate             ;; amount of time spent training instead of working
  activity                  ;; activity chosen for current tick
  revenue                   ;; revenue of company for current tick
  strategy                  ;; "talent-factory", "cherry-picker", or "goldilocks"
  cumulative-revenue        ;; rolling revenue for strategy evaluation
  ticks-since-review        ;; ticks since last strategy review
]

globals [
  ticks-per-year
  market-mean-skill         ;; average skill across all employed workers
  market-mean-revenue       ;; average revenue across all companies
]

;; ---------------------------------------
;; setup
;; ---------------------------------------
to setup
  clear-all
  set-default-shape turtles "person"

  set ticks-per-year 100

  setup-patches
  setup-turtles
  update-market-stats
  color-patches

  reset-ticks
end

;; initialize the companies
to setup-patches
  ask patches with [self != patch 0 0] [
    set headcount (random (max-headcount - min-headcount + 1)) + min-headcount
    set hiring-threshold random max-hiring-threshold
    set coaching-rate random max-coaching-rate
    set strategy one-of ["talent-factory" "cherry-picker" "goldilocks"]
    ;;set strategy item (count patches with [strategy != "none" and strategy != 0] mod 3) ["talent-factory" "cherry-picker" "goldilocks"]
    set cumulative-revenue 0
    set ticks-since-review 0
    sprout headcount
  ]

  ;; handle the unemployed pool (patch 0 0)
  ask patch 0 0 [
    set headcount 0
    set hiring-threshold 0
    set coaching-rate 0
    set strategy "none"
    set cumulative-revenue 0
    set ticks-since-review 0
  ]
end

;; initialize the workers
to setup-turtles
  ask turtles [
    set age ((random 450) + 200) / 10  ;; we might have to skew this younger, seems pretty old
    set skill-level age * 10 * ((random 10) + 100) / 100
    set turnover-probability 1
    hide-turtle
  ]
  ;; update the patches
  ask patches [ set total-skill sum [skill-level] of turtles-here ]
end


;; ---------------------------------------
;; go - run one simulation timestep
;; ---------------------------------------
to go
  turnover
  increase-age
  update-market-stats

  ask patches with [self != patch 0 0] [
    set revenue 0
    fill-vacancies
    apply-strategy
    execute-activity
    set total-skill sum [skill-level] of turtles-here

    set revenue round revenue
    set cumulative-revenue cumulative-revenue + revenue
    set ticks-since-review ticks-since-review + 1

    ;; strategy switching
    if ticks-since-review >= strategy-review-interval [
      maybe-switch-strategy
    ]
  ]

  color-patches
  tick
end

;; ---------------------------------------
;; Market statistics
;; ---------------------------------------
to update-market-stats
  let employed turtles with [patch-here != patch 0 0]
  ifelse any? employed
    [ set market-mean-skill mean [skill-level] of employed ]
    [ set market-mean-skill 0 ]

  let companies patches with [self != patch 0 0]
  ifelse any? companies
    [ set market-mean-revenue mean [cumulative-revenue] of companies ]
    [ set market-mean-revenue 0 ]
end

;; ---------------------------------------
;; Procedures used for simulation
;; ---------------------------------------

to turnover
  ask turtles with [patch-here != patch 0 0] [
    let base-quit-chance turnover-probability

    let my-company-mean ifelse-value (count turtles-here > 1)
      [ mean [skill-level] of other turtles-here ]
      [ skill-level ]
    let relative-quality my-company-mean / max (list 1 market-mean-skill)

    let adjusted-chance base-quit-chance * (2 - relative-quality)
    set adjusted-chance max (list 0 (min (list 10 adjusted-chance)))

    if ((random 10000) / 100) < adjusted-chance [
      let destination nobody
      if skill-level > market-mean-skill [
        let my-skill skill-level
        let my-patch patch-here
        let poachers patches with [
          self != patch 0 0 and
          self != my-patch and
          count turtles-here < headcount and
          my-skill > hiring-threshold
        ]
        if any? poachers [
          set destination max-one-of poachers [total-skill / max (list 1 (count turtles-here))]
        ]
      ]
      ifelse destination != nobody [
        move-to destination
      ] [
        setxy 0 0
        hide-turtle
      ]
      set turnover-probability 0
    ]
  ]
end

to increase-age
  ask turtles [
    set age (age + (1 / ticks-per-year))
    if (age > 65) [
      hatch 1 [
        setxy 0 0
        set age 20 + random 10
        set skill-level age * 10 * ((random 10) + 100) / 100
        set turnover-probability 1
      ]
      die
    ]
  ]
end

;; tries to fill vacancies, needs to run in patch context
;; should we hire the candidates with the highest skill levels first?
to fill-vacancies
  let vacancies (headcount - (count turtles-here))
  if (vacancies > 0) [
    ;; Identify all qualified candidates, sorted by skill level
    let candidates (turtles-on patch 0 0) with [skill-level > hiring-threshold]

    if any? candidates [
      ;; get up to vacancies candidates from the pool, sorted by skill level descending
      ask max-n-of (min (list vacancies (count candidates))) candidates [skill-level] [
        move-to myself
      ]
    ]
  ]
end

;; ---------------------------------------
;; Strategy logic
;; ---------------------------------------

;; TALENT FACTORY: coach hard when behind the market, ease off when ahead
to apply-strategy
  if not any? turtles-here [ stop ]
  if strategy = "talent-factory" [
    let my-mean-skill ifelse-value (any? turtles-here) [mean [skill-level] of turtles-here] [0]
    let skill-gap (market-mean-skill - my-mean-skill)
    ;; coaching rate scales with how far behind we are (0-50%)
    ;; sigmoid-ish: when gap is 0, coach ~5%. when gap is large, coach up to ~50%
    let dynamic-rate 5 + (45 * max (list 0 (skill-gap / (abs skill-gap + 100))))
    ifelse (random 100 < dynamic-rate)
      [ set activity "coach-all" ]
      [ set activity "work" ]
    ;; low hiring threshold — we'll train them up
    set hiring-threshold min-hiring-threshold
  ]

  ;; CHERRY PICKER: never coach, but adjust standards based on staffing pressure
  if strategy = "cherry-picker" [
    set activity "work"
    let fill-ratio count turtles-here / max (list 1 headcount)
    ;; when understaffed, lower threshold; when full, raise it
    ;; non-linear: threshold drops steeply when very understaffed
    set hiring-threshold min-hiring-threshold + (max-hiring-threshold - min-hiring-threshold) * (fill-ratio ^ 2)
  ]

  ;; GOLDILOCKS: coach the bottom half, work the top half. split adapts to revenue
  if strategy = "goldilocks" [
    set activity "coach-selective"
    ;; hiring threshold sits in the middle
    set hiring-threshold (min-hiring-threshold + max-hiring-threshold) / 2
  ]
end

;; executes the chosen activity, needs to run in patch context
to execute-activity
  if not any? turtles-here [ stop ]
  if activity = "work" [
    ask turtles-here [
      do-work
    ]
  ]
  if activity = "coach-all" [
    ask turtles-here [
      do-coaching
    ]
  ]
  if activity = "coach-selective" [
    ;; Goldilocks: bottom half coaches, top half works
    ;; The split shifts based on revenue performance
    let revenue-ratio ifelse-value (market-mean-revenue > 0)
      [ cumulative-revenue / market-mean-revenue ]
      [ 1 ]
    ;; when underperforming, coach more people (up to 70%); when ahead, coach fewer (down to 30%)
    let coach-fraction 0.5 + (0.2 * (1 - min (list 2 revenue-ratio)))
    set coach-fraction max (list 0.3 (min (list 0.7 coach-fraction)))

    let n-here count turtles-here
    if n-here > 0 [
      let n-to-coach round (n-here * coach-fraction)
      ;; coach the lowest-skilled workers
      ask min-n-of (min (list n-to-coach n-here)) turtles-here [skill-level] [
        do-coaching
      ]
      ;; work the rest
      ask turtles-here with [not member? self min-n-of (min (list n-to-coach n-here)) turtles-here [skill-level]] [
        do-work
      ]
    ]
  ]
end

to do-coaching  ;; turtle procedure
  set skill-level skill-level + coaching-skill-increase / (1 + skill-level / 300)
  set turnover-probability (max (list 0 (turnover-probability - working-turnover-decrease)))
  set skill-level round skill-level
end

to do-work  ;; turtle procedure
  set skill-level skill-level + working-skill-increase / (1 + skill-level / 150)
  set turnover-probability (turnover-probability + working-turnover-increase)
  set revenue revenue + skill-level
  set skill-level round skill-level
end

;; ---------------------------------------
;; Strategy switching
;; ---------------------------------------
to maybe-switch-strategy
  ;; only switch if underperforming
  if cumulative-revenue < market-mean-revenue * 0.8 [
    ;; 30% chance to switch when underperforming
    if random 100 < 30 [
      ;; pick a different strategy
      let other-strategies filter [s -> s != strategy] ["talent-factory" "cherry-picker" "goldilocks"]
      set strategy one-of other-strategies
    ]
  ]
  ;; reset review counters
  set cumulative-revenue 0
  set ticks-since-review 0
end

to color-patches
  let companies patches with [self != patch 0 0]
  if not any? companies [ stop ]
  let max-patch-skill-level max [total-skill] of companies
  let min-patch-skill-level min [total-skill] of companies
  if max-patch-skill-level = min-patch-skill-level [
    set max-patch-skill-level min-patch-skill-level + 1
  ]
  ask patch 0 0 [
    set pcolor gray - 2
  ]
  ask companies [
    if strategy = "talent-factory" [
      set pcolor scale-color blue total-skill min-patch-skill-level max-patch-skill-level
    ]
    if strategy = "cherry-picker" [
      set pcolor scale-color red total-skill min-patch-skill-level max-patch-skill-level
    ]
    if strategy = "goldilocks" [
      set pcolor scale-color violet total-skill min-patch-skill-level max-patch-skill-level
    ]
  ]
end]]></code>
